{
  "name": "@nexus-ai-fs/pay",
  "version": "0.1.0",
  "description": "TypeScript SDK for Nexus Pay — agent payment API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:api-client": "sh -c 'test -d ../nexus-api-client/node_modules || npm --prefix ../nexus-api-client ci; npm --prefix ../nexus-api-client run build'",
    "prebuild": "npm run build:api-client",
    "build": "tsup",
    "pretest": "npm run build:api-client",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "prelint": "npm run build:api-client",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@nexus-ai-fs/api-client": "file:../nexus-api-client"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "keywords": [
    "nexus",
    "pay",
    "agent",
    "payments",
    "credits",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexi-lab/nexus",
    "directory": "packages/nexus-pay-ts"
  }
}
